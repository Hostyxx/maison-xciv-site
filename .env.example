# ─── Maison XCIV — Variables d'environnement ───────────────────────────────
# Copier ce fichier en .env et remplir les valeurs pour le développement local.
# Le fichier .env est dans .gitignore → ne jamais le committer.

NODE_ENV=development

# Secrets JWT — générer avec : node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
ADMIN_JWT_SECRET=remplacer-par-une-cle-aleatoire-longue
USER_JWT_SECRET=remplacer-par-une-autre-cle-aleatoire-longue

# Admins (JSON sur une seule ligne)
# Générer un hash : node -e "const b=require('bcryptjs');console.log(b.hashSync('VotreMotDePasse',12))"
ADMINS_CONFIG=[{"name":"Jailson","email":"jailson@maisonxciv.com","passwordHash":"VOTRE_HASH_BCRYPT"}]

# Origines autorisées (séparées par des virgules)
# En production sur Render, mettre l'URL de votre service
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
