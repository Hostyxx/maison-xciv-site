# ─── Maison XCIV — Variables d'environnement ───────────────────────────────
# Copier ce fichier en .env et remplir les valeurs.
# Le fichier .env est dans .gitignore → ne jamais le committer.

# ── Environnement ────────────────────────────────────────────────────────────
# development | production
NODE_ENV=production

# ── Port ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Secrets JWT ──────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=REMPLACER_PAR_UNE_CLE_ALEATOIRE_64_CHARS
USER_JWT_SECRET=REMPLACER_PAR_UNE_AUTRE_CLE_ALEATOIRE_64_CHARS

# ── Admins (JSON sur une seule ligne) ────────────────────────────────────────
# Générer un hash bcrypt :
#   node -e "const b=require('bcryptjs');console.log(b.hashSync('VotreMotDePasse',12))"
ADMINS_CONFIG=[{"name":"Jailson","email":"admin@maisonxciv.com","passwordHash":"VOTRE_HASH_BCRYPT"}]

# ── Origines CORS autorisées (séparées par des virgules) ─────────────────────
# En production VPS : seulement votre domaine HTTPS
ALLOWED_ORIGINS=https://maisonxciv.com
