# Dépendances
node_modules/

# Fichier export standalone à la racine (non utilisé par le serveur, 2.5MB inutile)
/index.html

# Données sensibles — ne jamais versionner
database/users.json
database/favorites.json
database/invoices.json

# Les configs admin/user utilisent maintenant des variables d'env → versionnables
# backend/config/admin.js      ← plus dans gitignore
# backend/config/userConfig.js ← plus dans gitignore

# Fichiers d'environnement (sauf .env.example qui sert de template)
.env
.env.local
.env.production
.env.development
*.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Fichiers système
.DS_Store
Thumbs.db
desktop.ini

# Éditeurs / IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code (mémoire locale, pas à versionner)
.claude/

